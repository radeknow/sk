$plik = "C:\Temp\godzina.txt"      # Ścieżka do pliku
$url  = "https://www.google.com"   # Strona do otwarcia

# === POBRANIE AKTUALNEJ GODZINY (co do minuty) ===
$czas = Get-Date -Format "yyyy-MM-dd HH:mm"

