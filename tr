#!/bin/bash

if [ "$#" -ne 2 ]; then
  echo "Użycie: $0 input.csv output.csv"
  exit 1
fi

INPUT="$1"
OUTPUT="$2"

START_TS=$(date +%s)
echo "Start: $(date '+%Y-%m-%d %H:%M:%S')"

SED_SCRIPT=$(mktemp)

########################################
# LISTA PODMIAN — EDYTUJ TUTAJ
########################################
readarray -t ZAMIANY << 'EOF'
ą|a
ę|e
ł|l
ó|o
ś|s
" |'
EOF
########################################

for LINIA in "${ZAMIANY[@]}"
do
  OLD="${LINIA%%|*}"
  NEW="${LINIA#*|}"

  [ -z "$OLD" ] && continue

  OLD_ESC=$(printf '%s\n' "$OLD" | sed 's/[\/&]/\\&/g')
  NEW_ESC=$(printf '%s\n' "$NEW" | sed 's/[\/&]/\\&/g')

  echo "s/$OLD_ESC/$NEW_ESC/g" >> "$SED_SCRIPT"
done

sed -f "$SED_SCRIPT" "$INPUT" > "$OUTPUT"

rm "$SED_SCRIPT"

END_TS=$(date +%s)
echo "Koniec: $(date '+%Y-%m-%d %H:%M:%S')"

ELAPSED=$((END_TS - START_TS))
echo "Czas wykonania: ${ELAPSED}s"

echo "Gotowe → $OUTPUT"
